---
import Layout from "../layout.astro";
import Photos from "../photos.json";
---

<head>
  <title>Photography | Louis Bourgault du Coudray</title>
</head>

<Layout>
  <div class="maincol">
    <h1>Photography Portfolio</h1>
    <br />
    <div class="photos">
      {
        Photos.all.map((photo, index) => (
          <img
            src={photo.thumbnail}
            loading="lazy"
            class="galleryImg"
            id={`photo-${index}`}
            data-fullUrl={photo.high_res}
          />
        ))
      }
    </div>
  </div>
  <br />
  <br />
  <br />
</Layout>

<div class="" id="lightbox">
  <button id="close">Close</button>
  <p id="loading">Loading...</p>
  <img id="lb-photo" />
</div>

<script>
  console.log("hello");

  const lightbox = document.getElementById("lightbox");
  const closeButton = document.getElementById("close");
  const lbImg = document.getElementById("lb-photo");
  const loading = document.getElementById("loading");

  const galleryImages = document.querySelectorAll(".gallery-img");
  console.log("initialised event listener");

  document.addEventListener("mousedown", (e) => {
    let target = e.target;
    const fullURL = e.target?.getAttribute("data-fullURL");
    console.log(fullURL);
    if (fullURL && fullURL != "") {
      openLightbox(fullURL);
    }
  });

  // lbImg?.addEventListener("load", () => {
  //   console.log("loaded!");
  //   loading?.classList.remove("loading");
  // });

  function openLightbox(fullURL: string) {
    loading?.classList.add("loading");
    lightbox?.classList.add("lb-visible");

    const loadImage = new Image();
    loadImage.src = fullURL;

    loadImage.onload = () => {
      lbImg?.setAttribute("src", fullURL);
      loading?.classList.remove("loading");
    };
    loadImage.onerror = () => {
      loading?.classList.remove("loading");
    };
  }

  closeButton?.addEventListener("mousedown", () => {
    lightbox?.classList.remove("lb-visible");
    lbImg?.removeAttribute("src");
  });
</script>

<style>
  .photos {
    padding-top: 0.5rem;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }
  a {
    text-decoration: none;
    color: #6a546d;
  }

  .photos img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
    border-radius: 8px;
    display: block;
  }

  #loading {
    display: none;
    position: fixed;
    top: 50%;
    right: 50%;
    color: white;
  }
  .loading {
    display: contents !important;
  }

  #lightbox {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    display: none;
    align-items: center;
    background: rgba(0, 0, 0, 0.9);
    justify-items: center;
    justify-content: center;
    /* why are there so many justify classes????? */
  }

  #close {
    position: fixed;
    right: 5px;
    top: 5px;
    padding: 1rem;
    background-color: black;
    color: white;
    border: none;
    border-radius: 0.5rem;
  }

  .lb-visible {
    display: flex !important;
  }

  #lb-photo {
    max-width: 100%;
    max-height: 100%;
  }

  @media (min-width: 900px) {
    .photos {
      grid-template-columns: repeat(6, minmax(0, 1fr));
    }
  }
</style>
